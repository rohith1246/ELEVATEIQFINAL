# Flask secret key (REQUIRED - generate a long random string)
SECRET_KEY=your-very-long-secret-key-here

# PostgreSQL connection string (REQUIRED)
DATABASE_URL=postgresql://user:password@localhost:5432/elevateiq

# Application environment (production/development)
FLASK_ENV=production

# Server port
PORT=5000

# Comma/space separated CORS origins (leave empty for same-origin only)
CORS_ORIGINS=

# Groq API key (optional - for AI advisor chatbot)
GROQ_API_KEY=

# Default seed passwords (optional - auto-generated strong passwords if not set)
ADMIN_PASSWORD=
EMP_PASSWORD=
STUDENT_PASSWORD=

# ── Email / Assessment System (SMTP via Gmail) ─────────────────────────────
# Generate a Gmail App Password at: https://myaccount.google.com/apppasswords
# Your Google account MUST have 2-Factor Authentication enabled first.
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Base URL of your deployed app (used in email links)
# For local development: http://localhost:5000
# For production: https://yourdomain.com
APP_BASE_URL=http://localhost:5000
