# Flask secret key (REQUIRED - generate a long random string)
SECRET_KEY=your-very-long-secret-key-here

# PostgreSQL connection string (REQUIRED)
DATABASE_URL=postgresql://user:password@localhost:5432/elevateiq

# Application environment (production/development)
FLASK_ENV=production

# Server port
PORT=5000

# Comma/space separated CORS origins (leave empty for same-origin only)
CORS_ORIGINS=

# Groq API key (optional - for AI advisor chatbot)
GROQ_API_KEY=

# Default seed passwords (optional - auto-generated strong passwords if not set)
ADMIN_PASSWORD=
EMP_PASSWORD=
STUDENT_PASSWORD=
